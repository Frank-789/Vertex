# ========================================
# VertexAI项目环境变量配置模板
# ========================================

# ---------- 前端环境变量 (Next.js) ----------
# 这些变量需要在Vercel或本地开发环境中设置
# 注意：Next.js公共变量需要以NEXT_PUBLIC_开头

# Supabase配置（必需）
NEXT_PUBLIC_SUPABASE_URL=你的Supabase项目URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的Supabase匿名密钥

# 后端API地址（必需）
# 开发环境：http://localhost:8000
# 生产环境：https://你的Railway域名.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI API密钥配置
# DeepSeek API（必需，用于智能对话）
DEEPSEEK_API_KEY=sk-你的DeepSeek-API密钥

# 其他AI API（可选）
DOUBAO_API_KEY=你的豆包API密钥
TONGYI_API_KEY=你的通义千问API密钥
ANTHROPIC_API_KEY=你的Claude API密钥
QWEN_API_KEY=你的通义千问API密钥

# 开发环境变量
NODE_ENV=development

# ---------- 后端环境变量 (Python) ----------
# 这些变量需要在Railway或本地Python环境中设置

# 应用配置
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
ENVIRONMENT=development

# Supabase配置（头像上传功能必需）
SUPABASE_URL=你的Supabase项目URL
SUPABASE_ANON_KEY=你的Supabase匿名密钥
SUPABASE_SERVICE_ROLE_KEY=你的Supabase服务角色密钥（可选）

# 数据库配置（如果需要）
# DATABASE_URL=postgresql://用户名:密码@主机:端口/数据库名

# Redis配置（如果需要，用于Celery任务队列）
# REDIS_URL=redis://localhost:6379/0

# ---------- Railway特定变量 ----------
# Railway会自动设置这些变量，无需手动配置
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=你的Railway域名

# ---------- 部署提示 ----------
# 1. 将本文件复制为.env.local（前端）或.env（后端）
# 2. 替换所有"你的xxx"为实际值
# 3. 不要将包含真实密钥的文件提交到GitHub
# 4. Railway环境变量在项目Variables页面设置